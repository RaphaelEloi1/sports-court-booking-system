generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Jogador {
  id           Int      @id @default(autoincrement())
  nome         String
  email        String   @unique
  telefone     String
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}